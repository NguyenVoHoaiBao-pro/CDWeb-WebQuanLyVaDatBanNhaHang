You need to create a config.properties file based on this template to use actual service (Google, Facebook, etc.)
# Google OAuth
google.client.id=YOUR_GOOGLE_CLIENT_ID
google.client.secret=YOUR_GOOGLE_CLIENT_SECRET
google.redirect.uri=http://localhost:8080/NhaHangCuaChungTa/login/oauth2/code/google

# Facebook OAuth
facebook.app.id=YOUR_FACEBOOK_APP_ID
facebook.app.secret=YOUR_FACEBOOK_APP_SECRET

# Email SMTP
mail.host=smtp.gmail.com
mail.port=587
mail.username=YOUR_EMAIL@gmail.com
mail.password=YOUR_APP_PASSWORD

# VNPay
vnpay.tmn.code=YOUR_TMN_CODE
vnpay.hash.secret=YOUR_HASH_SECRET
vnpay.pay.url=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Database
db.url=jdbc:mysql://localhost:3306/YOUR_DB_NAME?serverTimezone=Asia/Ho_Chi_Minh&useSSL=false&allowPublicKeyRetrieval=true
db.user=YOUR_DB_USER
db.password=YOUR_DB_PASSWORD